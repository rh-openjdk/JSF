# Define a build argument for the base image
ARG BASE_IMAGE=fedora:rawhide

# Use the argument in the FROM directive
FROM $BASE_IMAGE

# Define the RPMs directory argument
ARG RPMS_DIR

# Copy all RPMs from the specified directory into the container
# RPMs will be available at /rpms/ for use with rpm/rpmbuild commands
COPY $RPMS_DIR /rpms/

# Set the default command for the container
CMD ["bash"]